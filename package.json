{
  "name": "leathercraft-monorepo",
  "version": "1.0.0",
  "description": "LeatherCraft SaaS Platform — MERN Stack Monorepo",
  "scripts": {
    "predev": "npx kill-port 8000 5173 5174 5175 --silent 2>nul & exit 0",
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd client && npm run dev",
    "install:all": "cd backend && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1"
  }
}
